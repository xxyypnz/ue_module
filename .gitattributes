# =============================================================================
# UE5 Git LFS Attributes — Underwater Project (UE 5.3)
# =============================================================================
# 规则：所有二进制大文件走 LFS；文本文件走普通 diff。
# 请在首次 clone 后执行：git lfs install && git lfs pull

# -------------------------------------------------------
# UE 核心二进制资产（必须 LFS）
# -------------------------------------------------------
*.uasset    filter=lfs diff=lfs merge=lfs -text
*.umap      filter=lfs diff=lfs merge=lfs -text
*.uplugin   filter=lfs diff=lfs merge=lfs -text
*.uproject  filter=lfs diff=lfs merge=lfs -text

# -------------------------------------------------------
# 3D 源文件 / 导入源
# -------------------------------------------------------
*.fbx       filter=lfs diff=lfs merge=lfs -text
*.obj       filter=lfs diff=lfs merge=lfs -text
*.abc       filter=lfs diff=lfs merge=lfs -text
*.c4d       filter=lfs diff=lfs merge=lfs -text
*.blend     filter=lfs diff=lfs merge=lfs -text
*.ma        filter=lfs diff=lfs merge=lfs -text
*.mb        filter=lfs diff=lfs merge=lfs -text
*.max       filter=lfs diff=lfs merge=lfs -text

# -------------------------------------------------------
# 贴图 / 图像（含 Intro_Narrative 的原始图）
# -------------------------------------------------------
*.png       filter=lfs diff=lfs merge=lfs -text
*.jpg       filter=lfs diff=lfs merge=lfs -text
*.jpeg      filter=lfs diff=lfs merge=lfs -text
*.tga       filter=lfs diff=lfs merge=lfs -text
*.tif       filter=lfs diff=lfs merge=lfs -text
*.tiff      filter=lfs diff=lfs merge=lfs -text
*.exr       filter=lfs diff=lfs merge=lfs -text
*.hdr       filter=lfs diff=lfs merge=lfs -text
*.dds       filter=lfs diff=lfs merge=lfs -text
*.psd       filter=lfs diff=lfs merge=lfs -text
*.bmp       filter=lfs diff=lfs merge=lfs -text

# -------------------------------------------------------
# 音频
# -------------------------------------------------------
*.wav       filter=lfs diff=lfs merge=lfs -text
*.mp3       filter=lfs diff=lfs merge=lfs -text
*.ogg       filter=lfs diff=lfs merge=lfs -text
*.aif       filter=lfs diff=lfs merge=lfs -text
*.aiff      filter=lfs diff=lfs merge=lfs -text
*.flac      filter=lfs diff=lfs merge=lfs -text

# -------------------------------------------------------
# 视频 / 媒体（项目含 Media/ 文件夹）
# -------------------------------------------------------
*.mp4       filter=lfs diff=lfs merge=lfs -text
*.mov       filter=lfs diff=lfs merge=lfs -text
*.avi       filter=lfs diff=lfs merge=lfs -text
*.mkv       filter=lfs diff=lfs merge=lfs -text

# -------------------------------------------------------
# 编译产物 / 库（如有 C++ 模块）
# -------------------------------------------------------
*.dll       filter=lfs diff=lfs merge=lfs -text
*.lib       filter=lfs diff=lfs merge=lfs -text
*.pdb       filter=lfs diff=lfs merge=lfs -text
*.exp       filter=lfs diff=lfs merge=lfs -text
*.exe       filter=lfs diff=lfs merge=lfs -text

# -------------------------------------------------------
# 文本文件（正常 Git diff，不走 LFS）
# -------------------------------------------------------
*.ini       text eol=lf
*.cfg       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.csv       text eol=lf
*.py        text eol=lf
*.h         text eol=lf
*.cpp       text eol=lf
*.cs        text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
