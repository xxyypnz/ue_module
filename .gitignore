# =============================================================================
# UE5 Team .gitignore — Underwater Project (UE 5.3)
# =============================================================================

# -------------------------------------------------------
# 1. 本地构建缓存（绝不提交）
# -------------------------------------------------------
Binaries/
Build/
Intermediate/
DerivedDataCache/
.vs/
.vscode/
*.sln
*.suo
*.opensdf
*.sdf

# -------------------------------------------------------
# 2. 运行时产生的临时数据（每台机器独立生成）
# -------------------------------------------------------
Saved/
# 唯一例外：保留 DefaultEditor.ini 等 Config/ 根层 ini，
# 但忽略 Saved/Config（含本机编辑器布局、崩溃报告等）
Saved/Config/
Saved/Logs/
Saved/Crashes/
Saved/Autosaves/
Saved/SourceControl/
Saved/webcache*/
Saved/Collections/

# -------------------------------------------------------
# 3. 个人开发者沙盒（Content/Developers/<你的用户名>）
# 每人的草稿区不应进入主仓库
# -------------------------------------------------------
Content/Developers/

# -------------------------------------------------------
# 4. 未使用 / 废弃资产文件夹（明确标记为 Notuse）
# -------------------------------------------------------
Content/Blurprint/Notuse/

# -------------------------------------------------------
# 5. 原始源文件（已有对应 .uasset，不应重复进仓）
# -------------------------------------------------------
Content/Intro_Narrative/temp.jpg
Content/Intro_Narrative/tmp.png
Content/Intro_Narrative/temp.uasset

# -------------------------------------------------------
# 6. 操作系统 / 编辑器垃圾文件
# -------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.swp
*.bak
*~

# -------------------------------------------------------
# 7. 打包输出
# -------------------------------------------------------
Releases/
Packages/
Staged/

# -------------------------------------------------------
# 8. 隐藏的 Claude Code 工作目录（误入 Content/KB3D）
# -------------------------------------------------------
Content/KB3D/.claude/
